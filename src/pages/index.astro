---
import "../styles/global.css";
import BaseLayout from "@/layouts/base-layout.astro";
import MaxWidthWrapper from "@/components/max-width-wrapper.astro";

import { ArrowDown } from "@lucide/astro";

import FadeUpSection from "@/components/animations/fade-up-section.astro";

import HeroImage from "@/components/sections/home/hero-image.astro";
import AboutMe from "@/components/sections/home/about-me.astro";
import Technologies from "@/components/sections/home/technologies.astro";
---

<BaseLayout>
  <!-- <div class="flex flex-col w-full gap-2"> -->

  <section
    class="flex flex-col h-[calc(100svh-6rem)] w-full mx-auto px-3 sm:px-6 md:px-12 max-w-7xl"
  >
    <HeroImage />

    <div class="flex grow items-center justify-center h-1/6 lg:h-1/5 xl:h-1/4">
      <ArrowDown
        class="size-6 text-secondary-foreground animate-bounce duration-150"
      />
    </div>
  </section>

  <MaxWidthWrapper>
    <FadeUpSection>
      <AboutMe />
    </FadeUpSection>

    <FadeUpSection>
      <Technologies />
    </FadeUpSection>
  </MaxWidthWrapper>
  <!-- </div> -->
</BaseLayout>
