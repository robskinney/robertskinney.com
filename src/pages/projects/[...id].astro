---
import MaxWidthWrapper from "@/components/max-width-wrapper.astro";
import BaseLayout from "@/layouts/base-layout.astro";
import Prose from "@/components/prose.astro";
import { ChevronLeft, ChevronRight, ExternalLinkIcon } from "@lucide/astro";
import { getCollection, render } from "astro:content";
import Github from "@/components/icons/social/github.astro";
// 1. Generate a new path for every collection entry
export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}
// 2. For your template, you can get the entry directly from the prop
const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout
  content={{
    title: `Robert Kinney | ${project.data.title}`,
    description: `Robert Kinney's Portfolio | Project | ${project.data.title}`,
  }}
>
  <MaxWidthWrapper>
    <ol
      class="text-muted-foreground flex flex-wrap items-center gap-1.5 text-sm wrap-break-word sm:gap-2.5 pt-3"
    >
      <li class="inline-flex items-center gap-1.5">
        <a href="/projects" class="hover:text-foreground transition-colors"
          >Projects</a
        >
      </li>
      <li>
        <ChevronRight class="size-3.5" />
      </li>
      <li class="inline-flex items-center gap-1.5">
        <span class="text-foreground font-normal">{project.data.title}</span>
      </li>
    </ol>

    <div class="flex flex-row justify-between my-4">
      <div class="flex flex-col items-start gap-1">
        <h2 class="scroll-m-20 text-xl font-medium tracking-tight">
          {project.data.title}
        </h2>
        <p class="muted text-muted-foreground">
          Last updated {project.data.publishedAt.toLocaleDateString()}
        </p>
      </div>

      <div class="flex flex-row items-center gap-1.5">
        {
          project.data.github && (
            <a
              href={project.data.github}
              class="flex flex-row gap-1 items-center text-sm text-muted-foreground hover:text-accent-foreground p-0.5"
              target="_blank"
              aria-label="View on GitHub"
              data-tooltip="View on GitHub"
              data-side="bottom"
              data-align="end"
              rel="noopener noreferrer"
            >
              <Github class="size-4" />
            </a>
          )
        }
        {
          project.data.link && (
            <a
              href={project.data.link}
              class="flex flex-row gap-1 items-center text-sm text-muted-foreground hover:text-accent-foreground p-0.5"
              target="_blank"
              aria-label="Go to Project Website"
              data-tooltip="Go to Project Website"
              data-side="bottom"
              data-align="end"
              rel="noopener noreferrer"
            >
              <ExternalLinkIcon class="size-4" />
            </a>
          )
        }
      </div>
    </div>

    <Prose>
      <Content />
    </Prose>

    <hr class="mt-12" />

    <div class="flex justify-center pt-6 lg:pt-10">
      <a href="/projects">
        <div class="btn-ghost">
          <ChevronLeft class="mr-2 h-4 w-4" />
          Return to Projects
        </div>
      </a>
    </div>
  </MaxWidthWrapper>
</BaseLayout>
