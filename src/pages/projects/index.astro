---
export const prerender = false;

import "../../styles/global.css";
import BaseLayout from "@/layouts/base-layout.astro";
import TechnologyBadge from "@/components/technology-badge.astro";
import MaxWidthWrapper from "@/components/max-width-wrapper.astro";

import { getCollection } from "astro:content";
import { ExternalLinkIcon } from "@lucide/astro";
import Github from "@/components/icons/social/github.astro";
import ProjectsTable from "@/components/projects-table.astro";

const allProjects = await getCollection("projects");

const tagFilter = Astro.url.searchParams.get("tag");

const projects = tagFilter
  ? allProjects.filter((project) =>
      project.data.tags.some(
        (tag) => tag.toLowerCase() === tagFilter.toLowerCase(),
      ),
    )
  : allProjects;
---

<BaseLayout
  content={{
    title: "Robert Kinney | Projects",
    description: "Robert Kinney's Portfolio | Projects Page",
  }}
>
  <MaxWidthWrapper>
    <h2 class="scroll-m-20 text-xl font-medium tracking-tight pt-3">
      My Projects
    </h2>

    <ProjectsTable projects={projects} />
  </MaxWidthWrapper>
</BaseLayout>
