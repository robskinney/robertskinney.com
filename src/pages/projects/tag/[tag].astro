---
import "../../../styles/global.css";
import BaseLayout from "@/layouts/base-layout.astro";
import TechnologyBadge from "@/components/technology-badge.astro";
import MaxWidthWrapper from "@/components/max-width-wrapper.astro";

import { getCollection } from "astro:content";
import { ExternalLinkIcon, X } from "@lucide/astro";
import Github from "@/components/icons/social/github.astro";
import { findTechnologyBadge, TechnologyBadges } from "@/lib/data/technologies";
import ProjectsTable from "@/components/projects-table.astro";

export async function getStaticPaths() {
  const allProjects = await getCollection("projects");

  // Get all unique tags from your technology list
  const allTags = TechnologyBadges.flatMap((category) =>
    category.items.map((item) => item.name),
  );

  return allTags.map((tag) => ({
    params: { tag: tag.toLowerCase().replace(/\s+/g, "-") },
    props: {
      tagName: tag,
      projects: allProjects.filter((project) =>
        project.data.tags.some((t) => t.toLowerCase() === tag.toLowerCase()),
      ),
    },
  }));
}

const { tagName, projects } = Astro.props;

const tag = findTechnologyBadge(tagName);
---

<BaseLayout
  content={{
    title: `Robert Kinney | Projects - ${tagName}`,
    description: `Robert Kinney's projects using ${tagName}`,
  }}
>
  <MaxWidthWrapper>
    <div class="flex flex-row justify-between items-center gap-1 pt-3">
      <h2 class="scroll-m-20 text-xl font-medium tracking-tight">
        My Projects
      </h2>

      {
        tag && (
          <div class:list={["badge-outline items-center pl-2 pr-1", tag.color]}>
            Filtered: {tagName}
            <a
              type="button"
              href="/projects"
              class="btn-icon-ghost size-4 ml-auto"
            >
              <X class="size-2" />
            </a>
          </div>
        )
      }
    </div>

    <ProjectsTable projects={projects} />
  </MaxWidthWrapper>
</BaseLayout>
