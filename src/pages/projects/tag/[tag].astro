---
import "../../../styles/global.css";
import BaseLayout from "@/layouts/base-layout.astro";
import MaxWidthWrapper from "@/components/max-width-wrapper.astro";

import { getCollection } from "astro:content";
import { X } from "@lucide/astro";
import { findTechnologyBadge, TechnologyBadges } from "@/lib/data/technologies";
import ProjectsTable from "@/components/projects-table.astro";

export async function getStaticPaths() {
  const allProjects = await getCollection("projects");

  const allTags = TechnologyBadges.flatMap((category) =>
    category.items.map((item) => item.name),
  );

  return allTags.map((tag) => {
    const slug = tag
      .toLowerCase()
      .replace(/\s+/g, "-")
      .replace(/\//g, "-")
      .replace(/\./g, "-");

    const filteredProjects = allProjects.filter((project) =>
      project.data.tags?.some((t) => t.toLowerCase() === tag.toLowerCase()),
    );

    return {
      params: { tag: slug },
      props: {
        tagName: tag,
        projects: filteredProjects,
      },
    };
  });
}

const { tagName, projects } = Astro.props;
const tag = findTechnologyBadge(tagName);
---

<BaseLayout
  content={{
    title: `Robert Kinney | ${tagName} Projects`,
    description: `Robert Kinney's projects tagged with ${tagName}`,
  }}
>
  <MaxWidthWrapper>
    <div class="flex flex-row justify-between items-center gap-1 pt-3">
      <h2 class="scroll-m-20 text-xl font-medium tracking-tight">
        My Projects
      </h2>

      {
        tag && (
          <div
            class:list={[
              "badge-outline flex items-center gap-2 pl-2 pr-1",
              tag.color,
            ]}
          >
            <span>Filtered: {tagName}</span>
            <a
              href="/projects"
              class="btn-icon-ghost flex items-center justify-center size-5 rounded-full hover:bg-black/10 dark:hover:bg-white/10"
              aria-label="Clear filter"
            >
              <X class="size-3" />
            </a>
          </div>
        )
      }
    </div>

    {/* Optional: Add a fallback if no projects exist for a tag */}
    {
      projects.length > 0 ? (
        <ProjectsTable projects={projects} />
      ) : (
        <p class="py-10 text-muted-foreground text-center">
          No projects found with this tag.
        </p>
      )
    }
  </MaxWidthWrapper>
</BaseLayout>
