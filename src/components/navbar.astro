---
import { Image } from "astro:assets";
import { Home, House, Mail } from "@lucide/astro";
import siteFavicon from "../../public/favicon.svg";

const currentPath = Astro.url.pathname;
const isHome = currentPath === "/";
const isProjects = currentPath.startsWith("/projects");
---

<nav
  class="sticky w-full border-b z-50 bg-sidebar -top-[env(safe-area-inset-top,0px)]"
>
  <!-- Solid background layer that extends into safe area -->
  <!-- <div
    class="absolute inset-0 backdrop-blur-md -top-[env(safe-area-inset-top,0px)]"
  >
  </div> -->
  <!-- Semi-transparent blur layer for the actual navbar content area -->
  <!-- <div class="absolute inset-0 bg-primary backdrop-blur-md"></div> -->
  <div
    class="relative h-16 flex items-center justify-between px-3 sm:px-6 md:px-12 max-w-7xl mx-auto"
  >
    <a href="/" class="flex items-center gap-2 group">
      <Image
        src={siteFavicon || "/placeholder.svg"}
        loading="eager"
        alt="Logo"
        class="transition-transform duration-300 group-hover:rotate-45 size-7"
      />
    </a>

    <div class="flex items-center gap-0.5 p-1 rounded-full bg-muted/50">
      <a
        href="/"
        type="button"
        class:list={[
          "btn-sm-ghost transition-all duration-200",
          isHome
            ? "border bg-accent border-primary/60 text-primary dark:bg-primary/20 dark:text-foreground shadow-sm"
            : "text-foreground/60 hover:text-foreground",
        ]}
      >
        <House class="size-3.5" />
      </a>
      <a
        href="/projects"
        type="button"
        class:list={[
          "btn-sm-ghost text-xs transition-all duration-200",
          isProjects
            ? "border bg-accent border-primary/60 text-primary dark:bg-primary/20 dark:text-foreground shadow-sm"
            : "text-foreground/60 hover:text-foreground",
        ]}
      >
        Projects
      </a>
    </div>

    <a
      href="mailto:robertskinney@outlook.com?Subject=Inquiry"
      class="size-9 flex items-center justify-center rounded-full hover:bg-muted transition-colors"
      aria-label="Contact me"
    >
      <Mail class="size-4" />
    </a>
  </div>
</nav>
