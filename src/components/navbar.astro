---
import { Image } from "astro:assets";
import { Mail } from "@lucide/astro";
import siteFavicon from "../../public/favicon.svg";

const currentPath = Astro.url.pathname;
const isHome = currentPath === "/";
const isProjects = currentPath.startsWith("/projects");
---

<nav
  id="navbar"
  class="sticky top-0 w-full bg-sidebar border-b z-50 h-20 transition-all duration-300"
>
  <div
    class="h-full flex items-center mx-auto justify-between py-5 px-3 sm:px-6 md:px-12 max-w-7xl"
  >
    <a href="/" class="underline">
      <Image
        src={siteFavicon}
        loading="eager"
        alt="A purple square outline logo."
        class="transition-all hover:rotate-45 size-6"
      />
    </a>

    <div class="flex items-center gap-2">
      <a href="/">
        <button
          class:list={[
            "btn-sm-ghost text-xs px-1 flex rounded-xs border-b-2",
            isHome ? "border-primary/75" : "border-transparent",
          ]}
          type="button"
        >
          home
        </button>
      </a>
      <a href="/projects">
        <button
          class:list={[
            "btn-sm-ghost text-xs px-1 flex rounded-xs border-b-2",
            isProjects ? "border-primary/75" : "border-transparent",
          ]}
          type="button"
        >
          projects
        </button>
      </a>
    </div>

    <div class="flex items-center gap-3">
      <a
        href="mailto:robertskinney@outlook.com?Subject=Inquiry to Robert Kinney"
      >
        <button
          id="contact-button"
          type="button"
          aria-label="Contact me"
          data-tooltip="Contact me"
          data-side="bottom"
          data-align="end"
          onclick="document.dispatchEvent(new CustomEvent('basecoat:theme'))"
          class="btn-icon-ghost rounded-xs size-8"
        >
          <Mail class="stroke-2" />
        </button>
      </a>
    </div>
  </div>
</nav>
